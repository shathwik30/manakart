generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}



model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  cart      Cart?

  @@map("users")
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}

model Address {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String
  phone     String
  email     String
  street    String
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("addresses")
}

enum Role {
  USER
  ADMIN
}



model Product {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  category       String
  description    String?
  basePrice      Int
  images         String[]
  sizeChart      Json?
  availableSizes String[]
  stockPerSize   Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  outfitItems OutfitItem[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

model Outfit {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  genderType  GenderType
  description String?
  heroImages  String[]
  bundlePrice Int
  isActive    Boolean    @default(true)
  isFeatured  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items     OutfitItem[]
  cartItems CartItem[]

  @@index([genderType])
  @@index([isActive])
  @@map("outfits")
}

model OutfitItem {
  id        String  @id @default(cuid())
  outfit    Outfit  @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  outfitId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  position  Int     @default(0)

  @@unique([outfitId, productId])
  @@index([outfitId])
  @@map("outfit_items")
}

enum GenderType {
  GENTLEMEN
  LADY
  COUPLE
}



model Cart {
  id        String     @id @default(cuid())
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?    @unique
  sessionId String?    @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id            String   @id @default(cuid())
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId        String
  outfit        Outfit?  @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  outfitId      String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String?
  selectedSizes Json
  quantity      Int      @default(1)
  isBundle      Boolean  @default(false)
  priceSnapshot Int
  createdAt     DateTime @default(now())

  @@index([cartId])
  @@map("cart_items")
}



model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  items           OrderItem[]
  subtotal        Int
  deliveryCharge  Int           @default(0)
  discount        Int           @default(0)
  total           Int
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponId        String?
  paymentStatus   PaymentStatus @default(PENDING)
  orderStatus     OrderStatus   @default(CREATED)
  paymentId       String?
  paymentMethod   String?
  addressSnapshot Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([orderStatus])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  outfitId     String?
  outfitTitle  String?
  productTitle String
  size         String
  quantity     Int
  price        Int

  @@index([orderId])
  @@map("order_items")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}



model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  value         Int
  minOrderValue Int?
  maxDiscount   Int?
  usageLimit    Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  orders Order[]

  @@map("coupons")
}

enum DiscountType {
  FLAT
  PERCENTAGE
}



model Review {
  id         String   @id @default(cuid())
  userName   String
  rating     Int
  comment    String?
  media      String[]
  isFeatured Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([isFeatured])
  @@map("reviews")
}



model HeroContent {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  ctaText   String?
  ctaLink   String?
  isActive  Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("hero_content")
}

model Reel {
  id        String   @id @default(cuid())
  videoUrl  String
  thumbnail String?
  title     String?
  outfitId  String?
  isActive  Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("reels")
}