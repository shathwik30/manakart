NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Neon Database - Use sslmode=verify-full for secure connections
DATABASE_URL="postgresql://user:password@ep-xxx-xxx-pooler.region.aws.neon.tech/dbname?sslmode=verify-full"

JWT_SECRET="your-secret-key-at-least-32-characters-long"
ADMIN_SECRET_KEY="your-admin-key-at-least-16-chars"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Your Brand <noreply@yourdomain.com>"

RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
